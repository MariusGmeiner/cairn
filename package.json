{
  "name": "cairn",
  "version": "0.1.0",
  "description": "Command-line Assistant Interface for Roadmaps and Next actions — a terminal-native PM assistant for solo devs, one per git repo.",
  "type": "module",
  "bin": {
    "cairn": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "prepare": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "tui",
    "ink",
    "cli",
    "project-management",
    "roadmap",
    "backlog",
    "claude-code"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chokidar": "^3.6.0",
    "ink": "^5.0.1",
    "react": "^18.3.1",
    "yaml": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
